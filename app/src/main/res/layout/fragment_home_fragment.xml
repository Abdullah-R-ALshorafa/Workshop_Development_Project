<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    tools:context=".MainScreens.home_fragment">

    <TextView
        android:id="@+id/welcomeTv"
        style="@style/AppText.ScreenTitle"
        android:text="@string/welcome_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/goodMorningTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/good_morning"
        android:textColor="@color/black"
        android:textSize="@dimen/text_size_caption"
        app:layout_constraintStart_toStartOf="@id/welcomeTv"
        app:layout_constraintTop_toBottomOf="@id/welcomeTv" />

    <ImageView
        android:layout_width="@dimen/icon_size_medium"
        android:layout_height="@dimen/icon_size_medium"
        android:layout_marginEnd="35dp"
        android:background="@drawable/notification_shape"
        android:contentDescription="@string/all"
        android:padding="4dp"
        android:src="@drawable/notification_icon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/welcomeTv" />

    <!-- Balance Section -->
    <TextView
        android:id="@+id/tvBalanceTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_small"
        android:text="@string/total_balance"
        android:textColor="#1F1F1F"
        android:textSize="@dimen/text_size_caption"
        app:layout_constraintBottom_toBottomOf="@id/balanceArrowIv"
        app:layout_constraintStart_toEndOf="@id/balanceArrowIv"
        app:layout_constraintTop_toTopOf="@id/balanceArrowIv" />

    <ImageView
        android:id="@+id/balanceArrowIv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="41dp"
        android:contentDescription="@string/total_balance"
        android:src="@drawable/balance_arrow"
        app:layout_constraintStart_toStartOf="@id/goodMorningTv"
        app:layout_constraintTop_toBottomOf="@id/goodMorningTv" />

    <TextView
        android:id="@+id/tvBalance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$7,783.00"
        android:textColor="#FFFFFF"
        android:textSize="@dimen/text_size_xlarge"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@id/balanceArrowIv"
        app:layout_constraintTop_toBottomOf="@id/tvBalanceTitle" />

    <!-- Divider -->
    <View
        android:id="@+id/divider"
        android:layout_width="1dp"
        android:layout_height="40dp"
        android:layout_marginStart="40dp"
        android:background="#BFFFFFFF"
        app:layout_constraintBottom_toBottomOf="@+id/tvBalance"
        app:layout_constraintStart_toEndOf="@id/tvBalance"
        app:layout_constraintTop_toTopOf="@id/tvBalance" />

    <!-- Expense Section -->
    <TextView
        android:id="@+id/tvExpenseTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_small"
        android:text="@string/total_expense"
        android:textColor="#1F1F1F"
        android:textSize="@dimen/text_size_caption"
        app:layout_constraintBottom_toBottomOf="@id/expenseArrowIv"
        app:layout_constraintStart_toEndOf="@id/expenseArrowIv"
        app:layout_constraintTop_toTopOf="@id/expenseArrowIv" />

    <ImageView
        android:id="@+id/expenseArrowIv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:contentDescription="@string/total_expense"
        android:src="@drawable/expense_arrow"
        app:layout_constraintStart_toEndOf="@id/divider"
        app:layout_constraintTop_toTopOf="@id/balanceArrowIv" />

    <TextView
        android:id="@+id/tvExpense"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="-$1,187.40"
        android:textColor="#0D6EFD"
        android:textSize="@dimen/text_size_xlarge"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/divider"
        app:layout_constraintStart_toStartOf="@id/expenseArrowIv"
        app:layout_constraintTop_toBottomOf="@id/expenseArrowIv" />

    <!-- Expense Status -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_large"
        android:text="@string/expense_status"
        android:textColor="#000"
        android:textSize="@dimen/text_size_body"
        app:layout_constraintEnd_toEndOf="@id/tvExpense"
        app:layout_constraintStart_toStartOf="@id/tvBalance"
        app:layout_constraintTop_toBottomOf="@id/divider" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/margin_xlarge"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardElevation="@dimen/card_elevation_medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvStatus">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1dp"
            android:background="@drawable/card_corners"
            android:orientation="vertical"
            android:padding="@dimen/padding_large">

            <!-- TOP GREEN CARD -->
            <androidx.cardview.widget.CardView
                android:id="@+id/statsCard"
                android:layout_width="0dp"
                android:layout_height="160dp"
                app:cardBackgroundColor="#16C1A2"
                app:cardCornerRadius="@dimen/corner_radius_xlarge"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="@dimen/padding_large">

                    <!-- Savings circle -->
                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/miniPieChart"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvSavings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/savings_on_goals"
                        android:textColor="#000"
                        android:textSize="@dimen/text_size_caption"
                        android:textAlignment="center"
                        app:layout_constraintEnd_toEndOf="@+id/miniPieChart"
                        app:layout_constraintStart_toStartOf="@id/miniPieChart"
                        app:layout_constraintTop_toBottomOf="@id/miniPieChart" />

                    <!-- Divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="120dp"
                        android:layout_marginStart="@dimen/margin_medium"
                        android:background="#BFFFFFFF"
                        app:layout_constraintStart_toEndOf="@id/miniPieChart"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Revenue -->
                    <ImageView
                        android:id="@+id/revenueIcon"
                        android:layout_width="@dimen/icon_size_medium"
                        android:layout_height="@dimen/icon_size_medium"
                        android:layout_marginStart="40dp"
                        android:contentDescription="@string/revenue_last_week"
                        android:src="@drawable/mony_icon"
                        app:layout_constraintStart_toEndOf="@id/miniPieChart"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/revenueTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_small"
                        android:text="@string/revenue_last_week"
                        android:textSize="@dimen/text_size_caption"
                        app:layout_constraintStart_toEndOf="@id/revenueIcon"
                        app:layout_constraintTop_toTopOf="@id/revenueIcon" />

                    <TextView
                        android:id="@+id/revenueValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$4,000.00"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="@id/revenueTitle"
                        app:layout_constraintTop_toBottomOf="@id/revenueTitle" />

                    <!-- divider line -->
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_marginTop="10dp"
                        android:background="#BFFFFFFF"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="@id/revenueTitle"
                        app:layout_constraintTop_toBottomOf="@id/revenueValue" />

                    <!-- last payment -->
                    <ImageView
                        android:id="@+id/lastExpenseIcon"
                        android:layout_width="@dimen/icon_size_medium"
                        android:layout_height="@dimen/icon_size_medium"
                        android:layout_marginTop="@dimen/margin_large"
                        android:contentDescription="@string/last_expense"
                        android:src="@drawable/expense_arrow"
                        app:layout_constraintStart_toStartOf="@id/revenueIcon"
                        app:layout_constraintTop_toBottomOf="@id/revenueValue" />

                    <TextView
                        android:id="@+id/lastExpenseTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_small"
                        android:text="@string/last_expense"
                        android:textSize="@dimen/text_size_caption"
                        app:layout_constraintStart_toEndOf="@id/lastExpenseIcon"
                        app:layout_constraintTop_toTopOf="@id/lastExpenseIcon" />

                    <TextView
                        android:id="@+id/lastPaymentTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-$100.00"
                        android:textColor="#0D6EFD"
                        android:textSize="@dimen/text_size_subtitle"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="@id/lastExpenseTitle"
                        app:layout_constraintTop_toBottomOf="@id/lastExpenseTitle" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>


            <!-- SELECTOR -->
            <LinearLayout
                android:id="@+id/timeSelector"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginTop="@dimen/margin_large"
                android:background="#DDF5E0"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="6dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/statsCard">

                <Button
                    android:id="@+id/showAllBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="#16BFA1"
                    android:text="@string/all"
                    android:textColor="@color/black" />


                <Button
                    android:id="@+id/monthSortBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="#DDF5E0"
                    android:text="@string/monthly"
                    android:textColor="@color/black" />

                <Button
                    android:id="@+id/yearSortBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="#DDF5E0"
                    android:text="@string/yearly"
                    android:textColor="@color/black" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewHome"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:paddingTop="@dimen/padding_small"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/timeSelector" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/addTransactionFb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/margin_large"
                android:contentDescription="@string/add_transaction"
                android:src="@drawable/add_icon"
                app:backgroundTint="#16C1A2"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:tint="@android:color/white" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
