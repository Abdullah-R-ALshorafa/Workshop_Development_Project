<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainScreens.home_fragment"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/AppBackgroundColor"
    >

    <TextView
        android:id="@+id/welcomeTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="38dp"
        android:layout_marginTop="60dp"
        android:text="Hi, Welcome Back"
        android:textColor="@color/black"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/goodMorningTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Good Morning"
        android:textColor="@color/black"
        android:textSize="15sp"
        app:layout_constraintStart_toStartOf="@id/welcomeTv"
        app:layout_constraintTop_toBottomOf="@id/welcomeTv" />

    <ImageView
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginEnd="35dp"
        android:background="@drawable/notification_shape"
        android:padding="4dp"
        android:src="@drawable/notification_icon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/welcomeTv" />
    <!-- Balance Section -->
    <TextView
        android:id="@+id/tvBalanceTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:layout_marginStart="5dp"
        android:text="Total Balance"
        android:textColor="#1F1F1F"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@id/balanceArrowIv"
        app:layout_constraintStart_toEndOf="@id/balanceArrowIv"
        app:layout_constraintTop_toTopOf="@id/balanceArrowIv" />

    <ImageView
        android:id="@+id/balanceArrowIv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="41dp"
        android:src="@drawable/balance_arrow"
        app:layout_constraintStart_toStartOf="@id/goodMorningTv"
        app:layout_constraintTop_toBottomOf="@id/goodMorningTv" />


    <TextView
        android:id="@+id/tvBalance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$7,783.00"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@id/balanceArrowIv"
        app:layout_constraintTop_toBottomOf="@id/tvBalanceTitle" />

    <!-- Divider -->
    <View
        android:id="@+id/divider"
        android:layout_width="1dp"
        android:layout_height="40dp"
        android:layout_marginStart="40dp"
        android:background="#BFFFFFFF"
        app:layout_constraintBottom_toBottomOf="@+id/tvBalance"
        app:layout_constraintStart_toEndOf="@id/tvBalance"
        app:layout_constraintTop_toTopOf="@id/tvBalance" />

    <!-- Expense Section -->
    <TextView
        android:id="@+id/tvExpenseTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:text="Total Expense"
        android:textColor="#1F1F1F"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@id/expenseArrowIv"
        app:layout_constraintStart_toEndOf="@id/expenseArrowIv"
        app:layout_constraintTop_toTopOf="@id/expenseArrowIv" />

    <ImageView
        android:id="@+id/expenseArrowIv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:src="@drawable/expense_arrow"
        app:layout_constraintStart_toEndOf="@id/divider"
        app:layout_constraintTop_toTopOf="@id/balanceArrowIv" />


    <TextView
        android:id="@+id/tvExpense"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="-$1,187.40"
        android:textColor="#0D6EFD"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/divider"
        app:layout_constraintStart_toStartOf="@id/expenseArrowIv"
        app:layout_constraintTop_toBottomOf="@id/expenseArrowIv" />


    <!-- Expense Status -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="✔ 30% Of Your Expenses, Looks Good."
        android:textColor="#000"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="@id/tvExpense"
        app:layout_constraintStart_toStartOf="@id/tvBalance"
        app:layout_constraintTop_toBottomOf="@id/divider" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardElevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvStatus">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1dp"
            android:background="@drawable/card_corners"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- TOP GREEN CARD -->
            <androidx.cardview.widget.CardView
                android:id="@+id/statsCard"
                android:layout_width="0dp"
                android:layout_height="160dp"
                app:cardBackgroundColor="#16C1A2"
                app:cardCornerRadius="28dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="20dp">

                    <!-- Savings circle -->
                    <ImageView
                        android:id="@+id/savingsIcon"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:src="@drawable/car_icon"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvSavings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Savings\nOn Goals"
                        android:textColor="#000"
                        android:textSize="14sp"
                        app:layout_constraintEnd_toEndOf="@+id/savingsIcon"
                        app:layout_constraintStart_toStartOf="@id/savingsIcon"
                        app:layout_constraintTop_toBottomOf="@id/savingsIcon" />

                    <!-- Divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="120dp"
                        android:layout_marginStart="24dp"
                        android:background="#BFFFFFFF"
                        app:layout_constraintStart_toEndOf="@id/savingsIcon"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Revenue -->
                    <ImageView
                        android:id="@+id/revenueIcon"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_marginStart="60dp"
                        android:src="@drawable/mony_icon"
                        app:layout_constraintStart_toEndOf="@id/savingsIcon"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/revenueTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Revenue Last Week"
                        android:textSize="14sp"
                        app:layout_constraintStart_toEndOf="@id/revenueIcon"
                        app:layout_constraintTop_toTopOf="@id/revenueIcon" />

                    <TextView
                        android:id="@+id/revenueValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$4.000.00"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="@id/revenueTitle"
                        app:layout_constraintTop_toBottomOf="@id/revenueTitle" />

                    <!-- divider line -->
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_marginTop="10dp"
                        android:background="#BFFFFFFF"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="@id/revenueTitle"
                        app:layout_constraintTop_toBottomOf="@id/revenueValue" />

                    <!-- Food -->
                    <ImageView
                        android:id="@+id/foodIcon"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_marginTop="20dp"
                        android:src="@drawable/food_icon"
                        app:layout_constraintStart_toStartOf="@id/revenueIcon"
                        app:layout_constraintTop_toBottomOf="@id/revenueValue" />

                    <TextView
                        android:id="@+id/foodTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Food Last Week"
                        android:textSize="14sp"
                        app:layout_constraintStart_toEndOf="@id/foodIcon"
                        app:layout_constraintTop_toTopOf="@id/foodIcon" />

                    <TextView
                        android:id="@+id/foodValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-$100.00"
                        android:textColor="#0D6EFD"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="@id/foodTitle"
                        app:layout_constraintTop_toBottomOf="@id/foodTitle" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>


            <!-- SELECTOR -->
            <LinearLayout
                android:id="@+id/timeSelector"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:background="#DDF5E0"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="6dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/statsCard">


                <Button
                    android:id="@+id/monthSortBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="#DDF5E0"
                    android:text="Monthly"
                    android:textColor="@color/black" />

                <Button
                    android:id="@+id/yearSortBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="#16BFA1"
                    android:text="Yearly"
                    android:textColor="@color/black" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewHome"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:paddingTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/timeSelector" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>