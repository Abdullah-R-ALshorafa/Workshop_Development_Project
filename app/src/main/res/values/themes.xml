<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Workshop_Development_Project" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/background_main</item>
        <item name="android:statusBarColor">@color/background_main</item>
        <item name="android:windowLightStatusBar">false</item> <!-- Green background, white icons usually look better -->

        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/green</item>
        <item name="colorPrimaryVariant">@color/green_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Status bar color. -->
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
    </style>

    <style name="Theme.Workshop_Development_Project" parent="Base.Theme.Workshop_Development_Project" />
</resources>
